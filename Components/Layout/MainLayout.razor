@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row">
            <div>
                <strong>YKodeX Business</strong>
                <span>Sales, purchase, stock and tax workspace</span>
            </div>
            <div class="top-actions">
                <span>Today: @DateTime.Now.ToString("dd MMM yyyy")</span>
                <a href="settings">Settings</a>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>
