@page "/settings"

<PageTitle>Settings</PageTitle>

<section class="hero-strip">
    <div>
        <p class="eyebrow">System settings</p>
        <h1>Settings</h1>
        <p class="subtle">Company profile, language, printer and security settings.</p>
    </div>
    <span class="status">Configured</span>
</section>

<section class="split" style="margin-top:18px">
    <div class="panel">
        <h2>Company</h2>
        <div class="form-grid" style="margin-top:14px">
            <div class="field full"><label>Company Name</label><input value="YKodeX Trading" /></div>
            <div class="field"><label>Email</label><input value="user@example.com" /></div>
            <div class="field"><label>Language</label><select><option>English</option><option>Arabic</option><option>Malayalam</option></select></div>
            <div class="field full"><label>Address</label><textarea>Riyadh, Saudi Arabia</textarea></div>
        </div>
    </div>
    <div class="panel">
        <h2>Printer & Security</h2>
        <div class="form-grid" style="margin-top:14px">
            <div class="field"><label>Printer Type</label><select><option>Thermal 80mm</option><option>Sunmi</option><option>A4</option></select></div>
            <div class="field"><label>Invoice Copies</label><input type="number" value="1" /></div>
            <div class="field"><label>Auto Logout</label><select><option>30 minutes</option><option>1 hour</option><option>Never</option></select></div>
            <div class="field"><label>Backup</label><select><option>Daily</option><option>Weekly</option></select></div>
        </div>
        <div class="toolbar"><button type="button">Save Settings</button></div>
    </div>
</section>
